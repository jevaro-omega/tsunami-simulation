<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <title>Dreiecksgitter 2 Ebenen - TORUS (periodisch)</title>
    <style>
        body { margin: 0; overflow: hidden; background-color: #0a1a2f; color: white; font-family: sans-serif; }
        #info {
            position: absolute; top: 20px; left: 20px;
            background: rgba(0,0,0,0.6); padding: 8px 16px; border-radius: 30px;
            border: 1px solid #3f6a9c; z-index: 10;
            pointer-events: none;
        }
        #controls {
            position: absolute; bottom: 30px; left: 50%; transform: translateX(-50%);
            display: flex; gap: 12px; background: rgba(0,0,0,0.7); padding: 20px 25px;
            border-radius: 60px; border: 1px solid #3f6a9c; z-index: 20;
            align-items: center; backdrop-filter: blur(5px);
            flex-wrap: wrap; justify-content: center;
        }
        .slider-container {
            display: flex; flex-direction: column; align-items: center; gap: 5px;
            min-width: 120px;
        }
        .slider-container label {
            color: #ffd966; font-weight: bold; font-size: 0.85rem;
        }
        .slider-container input {
            width: 110px; height: 6px; border-radius: 10px;
            background: #1e3a5f; outline: none; -webkit-appearance: none;
        }
        .slider-container input::-webkit-slider-thumb {
            -webkit-appearance: none; width: 18px; height: 18px; border-radius: 50%;
            background: #ffaa00; cursor: pointer; border: 2px solid white;
        }
        .value-display {
            color: #ffaa00; font-weight: bold; font-size: 0.9rem; min-width: 30px; text-align: center;
        }
        .button-container {
            display: flex; gap: 8px; margin-left: 5px;
        }
        button {
            background: #1e3a5f; border: none; color: white; font-size: 0.9rem;
            padding: 6px 14px; border-radius: 30px; cursor: pointer;
            border: 1px solid #4d7ab3; box-shadow: 0 3px 0 #0a1a2f;
            transition: 0.1s ease; font-weight: bold;
        }
        button:hover { background: #2b4f7a; transform: translateY(-2px); }
        button:active { transform: translateY(3px); }
        #clickHint {
            position: absolute; bottom: 120px; left: 50%; transform: translateX(-50%);
            color: #aaa; font-size: 0.9rem; background: rgba(0,0,0,0.5); padding: 4px 12px;
            border-radius: 20px; z-index: 15;
        }
    </style>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script>
    // OrbitControls – inline (Three.js r128, vereinfacht aber vollständig)
    THREE.OrbitControls = function(object, domElement) {
        this.object = object;
        this.domElement = domElement;
        this.enabled = true;
        this.target = new THREE.Vector3();
        this.enableDamping = false;
        this.dampingFactor = 0.05;
        this.enableZoom = true;
        this.zoomSpeed = 1.0;
        this.enableRotate = true;
        this.rotateSpeed = 1.0;
        this.enablePan = true;
        this.panSpeed = 1.0;
        this.minPolarAngle = 0;
        this.maxPolarAngle = Math.PI;
        this.minDistance = 0;
        this.maxDistance = Infinity;
 
        var scope = this;
        var STATE = { NONE:-1, ROTATE:0, ZOOM:1, PAN:2 };
        var state = STATE.NONE;
 
        var EPS = 1e-6;
        var spherical = new THREE.Spherical();
        var sphericalDelta = new THREE.Spherical();
        var scale = 1;
        var panOffset = new THREE.Vector3();
 
        var rotateStart = new THREE.Vector2();
        var rotateEnd   = new THREE.Vector2();
        var rotateDelta = new THREE.Vector2();
        var panStart = new THREE.Vector2();
        var panEnd   = new THREE.Vector2();
        var panDelta = new THREE.Vector2();
 
        function getAutoRotationAngle() { return 2 * Math.PI / 60 / 60 * scope.autoRotateSpeed; }
        function getZoomScale() { return Math.pow(0.95, scope.zoomSpeed); }
 
        function rotateLeft(angle) { sphericalDelta.theta -= angle; }
        function rotateUp(angle)   { sphericalDelta.phi   -= angle; }
 
        var panLeftV = new THREE.Vector3();
        function panLeft(distance, objectMatrix) {
            panLeftV.setFromMatrixColumn(objectMatrix, 0);
            panLeftV.multiplyScalar(-distance);
            panOffset.add(panLeftV);
        }
        var panUpV = new THREE.Vector3();
        function panUp(distance, objectMatrix) {
            panUpV.setFromMatrixColumn(objectMatrix, 1);
            panUpV.multiplyScalar(distance);
            panOffset.add(panUpV);
        }
        var panInternalV = new THREE.Vector3();
        function pan(deltaX, deltaY) {
            var el = scope.domElement;
            panInternalV.copy(scope.object.position).sub(scope.target);
            var targetDist = panInternalV.length();
            targetDist *= Math.tan((scope.object.fov / 2) * Math.PI / 180.0);
            panLeft(2 * deltaX * targetDist / el.clientHeight, scope.object.matrix);
            panUp(2 * deltaY * targetDist / el.clientHeight, scope.object.matrix);
        }
 
        function dollyIn(dollyScale)  { scale /= dollyScale; }
        function dollyOut(dollyScale) { scale *= dollyScale; }
 
        this.update = function() {
            var offset = new THREE.Vector3();
            var quat = new THREE.Quaternion().setFromUnitVectors(object.up, new THREE.Vector3(0,1,0));
            var quatInverse = quat.clone().invert();
            var lastPos = new THREE.Vector3();
            var lastQuat = new THREE.Quaternion();
 
            return function update() {
                var position = scope.object.position;
                offset.copy(position).sub(scope.target);
                offset.applyQuaternion(quat);
                spherical.setFromVector3(offset);
 
                spherical.theta += sphericalDelta.theta;
                spherical.phi   += sphericalDelta.phi;
                spherical.phi = Math.max(scope.minPolarAngle + EPS, Math.min(scope.maxPolarAngle - EPS, spherical.phi));
                spherical.makeSafe();
                spherical.radius *= scale;
                spherical.radius = Math.max(scope.minDistance, Math.min(scope.maxDistance, spherical.radius));
 
                scope.target.add(panOffset);
                offset.setFromSpherical(spherical);
                offset.applyQuaternion(quatInverse);
                position.copy(scope.target).add(offset);
                scope.object.lookAt(scope.target);
 
                if (scope.enableDamping) {
                    sphericalDelta.theta *= (1 - scope.dampingFactor);
                    sphericalDelta.phi   *= (1 - scope.dampingFactor);
                    panOffset.multiplyScalar(1 - scope.dampingFactor);
                } else {
                    sphericalDelta.set(0, 0, 0);
                    panOffset.set(0, 0, 0);
                }
                scale = 1;
                return false;
            };
        }();
 
        this.dispose = function() {
            scope.domElement.removeEventListener('contextmenu', onContextMenu);
            scope.domElement.removeEventListener('pointerdown', onPointerDown);
            scope.domElement.removeEventListener('wheel', onMouseWheel);
        };
 
        function onPointerDown(e) {
            if (!scope.enabled) return;
            if (e.button === 0) {
                state = STATE.ROTATE;
                rotateStart.set(e.clientX, e.clientY);
            } else if (e.button === 2) {
                state = STATE.PAN;
                panStart.set(e.clientX, e.clientY);
            }
            scope.domElement.ownerDocument.addEventListener('pointermove', onPointerMove);
            scope.domElement.ownerDocument.addEventListener('pointerup', onPointerUp);
        }
        function onPointerMove(e) {
            if (!scope.enabled) return;
            if (state === STATE.ROTATE) {
                rotateEnd.set(e.clientX, e.clientY);
                rotateDelta.subVectors(rotateEnd, rotateStart).multiplyScalar(scope.rotateSpeed);
                var el = scope.domElement;
                rotateLeft(2 * Math.PI * rotateDelta.x / el.clientHeight);
                rotateUp(2 * Math.PI * rotateDelta.y / el.clientHeight);
                rotateStart.copy(rotateEnd);
                scope.update();
            } else if (state === STATE.PAN) {
                panEnd.set(e.clientX, e.clientY);
                panDelta.subVectors(panEnd, panStart).multiplyScalar(scope.panSpeed);
                pan(panDelta.x, panDelta.y);
                panStart.copy(panEnd);
                scope.update();
            }
        }
        function onPointerUp() {
            scope.domElement.ownerDocument.removeEventListener('pointermove', onPointerMove);
            scope.domElement.ownerDocument.removeEventListener('pointerup', onPointerUp);
            state = STATE.NONE;
        }
        function onMouseWheel(e) {
            if (!scope.enabled || !scope.enableZoom) return;
            e.preventDefault();
            if (e.deltaY < 0) dollyOut(getZoomScale());
            else if (e.deltaY > 0) dollyIn(getZoomScale());
            scope.update();
        }
        function onContextMenu(e) { if (scope.enabled) e.preventDefault(); }
 
        scope.domElement.addEventListener('contextmenu', onContextMenu);
        scope.domElement.addEventListener('pointerdown', onPointerDown);
        scope.domElement.addEventListener('wheel', onMouseWheel, { passive: false });
 
        this.update();
    };
    </script>
</head>
<body>
    <div id="info">🔺 Dreiecksgitter TORUS · periodische Ränder (keine Reflexionen!) · einstellbare Wassertiefe</div>
    <div id="clickHint">👆 Tippe auf die Wasseroberfläche für Impuls</div>
    <div id="controls">
        <div class="slider-container">
            <label>💥 Intensität</label>
            <input type="range" id="intensitySlider" min="0.5" max="8.0" step="0.1" value="3.0">
            <span class="value-display" id="intensityValue">3.0</span>
        </div>
        <div class="slider-container">
            <label>⚡ Basis-Geschw.</label>
            <input type="range" id="speedSlider" min="0.5" max="3.0" step="0.1" value="1.5">
            <span class="value-display" id="speedValue">1.5</span>
        </div>
        <div class="slider-container">
            <label>🌊 Dämpfung</label>
            <input type="range" id="dampingSlider" min="0.99" max="1.0" step="0.0005" value="0.9995">
            <span class="value-display" id="dampingValue">0.9995</span>
        </div>
        <div class="slider-container">
            <label>🏔️ Topo-Stärke</label>
            <input type="range" id="topoStrengthSlider" min="0.5" max="3.0" step="0.1" value="1.5">
            <span class="value-display" id="topoStrengthValue">1.5</span>
        </div>
        <div class="slider-container">
            <label>🌊 Wasserbasis</label>
            <input type="range" id="baseSlider" min="1.0" max="10.0" step="0.1" value="2.0">
            <span class="value-display" id="baseValue">2.0</span>
        </div>
        <div class="button-container">
            <button id="resetBtn">⟲ Reset</button>
            <button id="terrainBtn">⛰️ Topographie ergänzen</button>
        </div>
    </div>
 
    <script>
        (function() {
            // --- Szene, Kamera, Renderer ---
            const scene = new THREE.Scene();
            scene.background = new THREE.Color(0x0a1a2f);
 
            const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 2000);
            camera.position.set(300, 200, 400);
            camera.lookAt(0, 0, 0);
 
            const renderer = new THREE.WebGLRenderer({ antialias: true, powerPreference: "high-performance" });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
            document.body.appendChild(renderer.domElement);
 
            const controls = new THREE.OrbitControls(camera, renderer.domElement);
            controls.enableDamping = true;
            controls.dampingFactor = 0.05;
            controls.target.set(0, 2, 0);
            controls.maxPolarAngle = Math.PI / 2;
 
            // --- Licht ---
            const ambientLight = new THREE.AmbientLight(0x404060);
            scene.add(ambientLight);
            const dirLight = new THREE.DirectionalLight(0xffffff, 1);
            dirLight.position.set(1, 2, 1);
            scene.add(dirLight);
            const backLight = new THREE.PointLight(0x446688, 0.5);
            backLight.position.set(-2, 1, -2);
            scene.add(backLight);
 
            // --- Gitterparameter (200x200 für gute Performance) ---
            const nX = 200;
            const nZ = 200;
            const spacing = 1.0;
            const offsetX = (nX - 1) * spacing / 2;
            const offsetZ = (nZ - 1) * spacing / 2;
 
            // --- Höhenfelder ---
            const bottomH = new Float32Array(nX * nZ);
            let surfaceBase = 2.0;
            for (let i = 0; i < nX * nZ; i++) {
                bottomH[i] = -2.0; // flacher Meeresboden
            }
 
            // --- Wellenzustand (Leapfrog) ---
            const u_prev = new Float32Array(nX * nZ);
            const u_cur  = new Float32Array(nX * nZ);
            const u_next = new Float32Array(nX * nZ);
 
            // --- Hilfsarray für Viskosität ---
            const u_laplace = new Float32Array(nX * nZ);
 
            // --- Parameter ---
            let baseSpeed = 1.5;
            let damping = 0.9995;
            let topoStrength = 1.5;
            const dt = 0.1;
            const g = 9.81;
            const viscosity = 0.001;
 
            // --- Regler ---
            const intensitySlider = document.getElementById('intensitySlider');
            const intensitySpan = document.getElementById('intensityValue');
            let intensity = 3.0;
            intensitySlider.addEventListener('input', (e) => {
                intensity = parseFloat(e.target.value);
                intensitySpan.textContent = intensity.toFixed(1);
            });
 
            const speedSlider = document.getElementById('speedSlider');
            const speedSpan = document.getElementById('speedValue');
            speedSlider.addEventListener('input', (e) => {
                baseSpeed = parseFloat(e.target.value);
                speedSpan.textContent = baseSpeed.toFixed(1);
            });
 
            const dampingSlider = document.getElementById('dampingSlider');
            const dampingSpan = document.getElementById('dampingValue');
            dampingSlider.addEventListener('input', (e) => {
                damping = parseFloat(e.target.value);
                dampingSpan.textContent = damping.toFixed(4);
            });
 
            const topoStrengthSlider = document.getElementById('topoStrengthSlider');
            const topoStrengthSpan = document.getElementById('topoStrengthValue');
            topoStrengthSlider.addEventListener('input', (e) => {
                topoStrength = parseFloat(e.target.value);
                topoStrengthSpan.textContent = topoStrength.toFixed(1);
            });
 
            const baseSlider = document.getElementById('baseSlider');
            const baseSpan = document.getElementById('baseValue');
            baseSlider.addEventListener('input', (e) => {
                surfaceBase = parseFloat(e.target.value);
                baseSpan.textContent = surfaceBase.toFixed(1);
            });
 
            // --- Hilfsfunktion: Dreiecksgitter erstellen ---
            function createMeshGeometry(heightMap, yBase) {
                const vertices = [];
                const indices = [];
                const colors = [];
 
                for (let i = 0; i < nX; i++) {
                    for (let k = 0; k < nZ; k++) {
                        const x = i * spacing - offsetX;
                        const z = k * spacing - offsetZ;
                        const idx = i * nZ + k;
                        const y = yBase + heightMap[idx];
                        vertices.push(x, y, z);
                    }
                }
 
                for (let i = 0; i < nX - 1; i++) {
                    for (let k = 0; k < nZ - 1; k++) {
                        const a = i * nZ + k;
                        const b = i * nZ + (k + 1);
                        const c = (i + 1) * nZ + k;
                        const d = (i + 1) * nZ + (k + 1);
                        indices.push(a, b, c);
                        indices.push(b, d, c);
                    }
                }
 
                const minY = -2.0;
                const maxY = 8.0;
                for (let i = 0; i < nX; i++) {
                    for (let k = 0; k < nZ; k++) {
                        const idx = i * nZ + k;
                        const y = yBase + heightMap[idx];
                        let t = (y - minY) / (maxY - minY);
                        t = Math.max(0, Math.min(1, t));
                        let r, g, b;
                        if (yBase < 0) { // Boden
                            r = 0.3 + t * 0.7;
                            g = 0.2 + t * 0.5;
                            b = 0.1 + t * 0.3;
                        } else { // Wasser
                            r = 0.2;
                            g = 0.5;
                            b = 1.0;
                        }
                        colors.push(r, g, b);
                    }
                }
 
                const geometry = new THREE.BufferGeometry();
                geometry.setAttribute('position', new THREE.Float32BufferAttribute(vertices, 3));
                geometry.setAttribute('color', new THREE.Float32BufferAttribute(colors, 3));
                geometry.setIndex(indices);
                geometry.computeVertexNormals();
                return geometry;
            }
 
            // --- Initiale Geometrien ---
            const bottomGeo = createMeshGeometry(bottomH, -2.0);
            const waterGeo  = createMeshGeometry(new Float32Array(nX * nZ), surfaceBase);
 
            const bottomMat = new THREE.MeshStandardMaterial({ vertexColors: true, emissive: 0x111111, flatShading: false });
            const waterMat  = new THREE.MeshStandardMaterial({ vertexColors: true, emissive: 0x112233, transparent: true, opacity: 0.8, side: THREE.DoubleSide });
 
            const bottomMesh = new THREE.Mesh(bottomGeo, bottomMat);
            const waterMesh  = new THREE.Mesh(waterGeo,  waterMat);
            scene.add(bottomMesh);
            scene.add(waterMesh);
 
            // Drahtgitter nur für statischen Meeresboden (Wasseroberfläche animiert sich – kein Wireframe)
            let bottomWireframe = new THREE.LineSegments(new THREE.EdgesGeometry(bottomGeo), new THREE.LineBasicMaterial({ color: 0xaa8866, opacity: 0.2, transparent: true }));
            bottomMesh.add(bottomWireframe);
 
            // --- Drift-Korrektur ---
            function gentleDriftCorrection() {
                let sum = 0;
                for (let i = 0; i < nX * nZ; i++) sum += u_cur[i];
                const mean = sum / (nX * nZ);
                if (Math.abs(mean) > 0.001) {
                    for (let i = 0; i < nX * nZ; i++) u_cur[i] -= mean * 0.01;
                }
            }
 
            // --- Interaktion: Klick → Impuls ---
            function onPointerDown(event) {
                event.preventDefault();
                const rect = renderer.domElement.getBoundingClientRect();
                const clientX = event.clientX;
                const clientY = event.clientY;
 
                const ndcX = (clientX - rect.left) / rect.width * 2 - 1;
                const ndcY = -((clientY - rect.top) / rect.height) * 2 + 1;
 
                const origin = new THREE.Vector3();
                const direction = new THREE.Vector3();
                origin.setFromMatrixPosition(camera.matrixWorld);
 
                const vector = new THREE.Vector3(ndcX, ndcY, 0.5);
                vector.unproject(camera);
                direction.copy(vector).sub(origin).normalize();
 
                const planeY = surfaceBase;
                if (Math.abs(direction.y) < 1e-6) return;
                const t = (planeY - origin.y) / direction.y;
                if (t < 0) return;
 
                const hitPoint = new THREE.Vector3().copy(origin).add(direction.multiplyScalar(t));
                const x = hitPoint.x;
                const z = hitPoint.z;
 
                let ci = Math.round((x + offsetX) / spacing);
                let ck = Math.round((z + offsetZ) / spacing);
                ci = Math.max(0, Math.min(nX - 1, ci));
                ck = Math.max(0, Math.min(nZ - 1, ck));
 
                const radius = 20;
                const strength = intensity;
                const impulse = new Float32Array(nX * nZ);
 
                for (let di = -radius; di <= radius; di++) {
                    for (let dk = -radius; dk <= radius; dk++) {
                        const dist = Math.sqrt(di * di + dk * dk);
                        if (dist <= radius) {
                            // TORUS: periodische Indizes beim Impuls
                            const ni = ((ci + di) % nX + nX) % nX;
                            const nk = ((ck + dk) % nZ + nZ) % nZ;
                            const factor = Math.exp(-dist * dist / (radius * radius / 4)) * strength;
                            impulse[ni * nZ + nk] += factor;
                        }
                    }
                }
 
                // Mittelwert abziehen, damit kein Gesamthub entsteht
                let sumImp = 0;
                for (let idx = 0; idx < nX * nZ; idx++) sumImp += impulse[idx];
                const meanImp = sumImp / (nX * nZ);
                for (let idx = 0; idx < nX * nZ; idx++) {
                    u_cur[idx] += impulse[idx] - meanImp;
                }
            }
 
            renderer.domElement.addEventListener('pointerdown', onPointerDown);
 
            // --- Laplace für Viskosität (8 Nachbarn, TORUS-periodisch) ---
            function computeLaplaceViscosity() {
                for (let i = 0; i < nX; i++) {
                    for (let k = 0; k < nZ; k++) {
                        const idx = i * nZ + k;
                        let sum = 0;
                        let count = 0;
                        for (let di = -1; di <= 1; di++) {
                            for (let dk = -1; dk <= 1; dk++) {
                                if (di === 0 && dk === 0) continue;
                                const ni = ((i + di) % nX + nX) % nX;
                                const nk = ((k + dk) % nZ + nZ) % nZ;
                                sum += u_cur[ni * nZ + nk];
                                count++;
                            }
                        }
                        u_laplace[idx] = (sum - count * u_cur[idx]) / count;
                    }
                }
            }
 
            // --- Wellenschritt (TORUS: alle Ränder periodisch) ---
            function waveStep() {
                computeLaplaceViscosity();
 
                for (let i = 0; i < nX; i++) {
                    for (let k = 0; k < nZ; k++) {
                        const idx = i * nZ + k;
 
                        // Wassertiefe
                        let depth = surfaceBase + u_cur[idx] - bottomH[idx];
                        if (depth < 0.1) depth = 0.1;
 
                        // CFL-Bedingung: c * dt / spacing <= 1 (verhindert numerische Instabilität)
                        const c_local = Math.max(0.2, Math.min(baseSpeed * Math.sqrt(g * depth / 10), spacing / dt));
                        const c2dt2 = (c_local * dt) * (c_local * dt);
 
                        // TORUS: periodische Nachbarn (keine Reflexion am Rand!)
                        const iL = ((i - 1) + nX) % nX;
                        const iR = (i + 1) % nX;
                        const kU = ((k - 1) + nZ) % nZ;
                        const kD = (k + 1) % nZ;
 
                        const left  = u_cur[iL * nZ + k];
                        const right = u_cur[iR * nZ + k];
                        const up    = u_cur[i  * nZ + kU];
                        const down  = u_cur[i  * nZ + kD];
 
                        const laplace  = left + right + up + down - 4 * u_cur[idx];
                        const viscTerm = viscosity * u_laplace[idx] * dt;
 
                        u_next[idx] = 2 * u_cur[idx] - u_prev[idx] + c2dt2 * laplace + viscTerm;
                    }
                }
 
                for (let i = 0; i < nX * nZ; i++) {
                    u_next[i] *= damping;
                    u_prev[i]  = u_cur[i];
                    u_cur[i]   = u_next[i];
                }
 
                gentleDriftCorrection();
            }
 
            // --- Reset ---
            function resetAll() {
                for (let i = 0; i < nX * nZ; i++) {
                    bottomH[i] = -2.0;
                    u_prev[i] = 0;
                    u_cur[i]  = 0;
                    u_next[i] = 0;
                }
                updateWaterGeometry();
                updateBottomGeometry();
            }
 
            // --- Topographie ergänzen (additiv, kein Reset!) ---
            function generateRandomTerrain() {
                // Kein Reset – Topographie wird auf das Bestehende aufaddiert.
 
                const totalCells = nX * nZ;
                const maxArea = 0.3 * totalCells;
                const maxRadius = Math.sqrt(maxArea / Math.PI);
 
                const i0 = Math.floor(Math.random() * nX);
                const k0 = Math.floor(Math.random() * nZ);
                const regionRadius = 20 + Math.random() * (maxRadius - 20);
 
                const hillCount = 20 + Math.floor(Math.random() * 60);
 
                for (let h = 0; h < hillCount; h++) {
                    const iHill = Math.floor(Math.random() * nX);
                    const kHill = Math.floor(Math.random() * nZ);
                    const hillRadius = 10 + Math.random() * 30;
                    const baseHeight = 2.0 + Math.random() * 6.0;
                    const height = baseHeight * topoStrength;
 
                    for (let di = -Math.floor(hillRadius); di <= Math.floor(hillRadius); di++) {
                        for (let dk = -Math.floor(hillRadius); dk <= Math.floor(hillRadius); dk++) {
                            // Fix: Hügel wrappen auf dem Torus (keine harten Randabschnitte)
                            const ni = ((iHill + di) % nX + nX) % nX;
                            const nk = ((kHill + dk) % nZ + nZ) % nZ;
 
                            // Torus-Distanz zur Region (kürzester Weg über Rand berücksichtigt)
                            const dri = Math.min(Math.abs(ni - i0), nX - Math.abs(ni - i0));
                            const drk = Math.min(Math.abs(nk - k0), nZ - Math.abs(nk - k0));
                            const distToRegion = Math.hypot(dri, drk);
 
                            if (distToRegion <= regionRadius) {
                                const distToHill = Math.sqrt(di * di + dk * dk);
                                if (distToHill <= hillRadius) {
                                    const factor = Math.exp(-distToHill * distToHill / (hillRadius * hillRadius / 3)) * height;
                                    bottomH[ni * nZ + nk] += factor;
                                }
                            }
                        }
                    }
                }
                updateBottomGeometry();
            }
 
            // --- Geometrie aktualisieren ---
            function updateWaterGeometry() {
                const positions = waterGeo.attributes.position.array;
                const colors    = waterGeo.attributes.color.array;
                const minH = -5.0;
                const maxH =  5.0;
                for (let i = 0; i < nX; i++) {
                    for (let k = 0; k < nZ; k++) {
                        const idx = i * nZ + k;
                        positions[idx * 3 + 1] = surfaceBase + u_cur[idx];
 
                        let t = (u_cur[idx] - minH) / (maxH - minH);
                        t = Math.max(0, Math.min(1, t));
                        let r, g, b;
                        if (t < 0.5) {
                            r = 0.2 + t * 0.8;
                            g = 0.5 + t;
                            b = 1.0;
                        } else {
                            r = 0.6 + (t - 0.5) * 1.8;
                            g = 1.0 - (t - 0.5) * 1.5;
                            b = 1.0 - (t - 0.5) * 1.5;
                        }
                        colors[idx * 3]     = r;
                        colors[idx * 3 + 1] = g;
                        colors[idx * 3 + 2] = b;
                    }
                }
                waterGeo.attributes.position.needsUpdate = true;
                waterGeo.attributes.color.needsUpdate    = true;
                waterGeo.computeVertexNormals();
            }
 
            function updateBottomGeometry() {
                const positions = bottomGeo.attributes.position.array;
                const colors    = bottomGeo.attributes.color.array;
                for (let i = 0; i < nX; i++) {
                    for (let k = 0; k < nZ; k++) {
                        const idx = i * nZ + k;
                        positions[idx * 3 + 1] = -2.0 + bottomH[idx];
 
                        let t = (bottomH[idx] + 2) / 10;
                        t = Math.max(0, Math.min(1, t));
                        colors[idx * 3]     = 0.3 + t * 0.7;
                        colors[idx * 3 + 1] = 0.2 + t * 0.5;
                        colors[idx * 3 + 2] = 0.1 + t * 0.3;
                    }
                }
                bottomGeo.attributes.position.needsUpdate = true;
                bottomGeo.attributes.color.needsUpdate    = true;
                bottomGeo.computeVertexNormals();
 
                // Wireframe nach Geometrie-Update neu aufbauen
                bottomMesh.remove(bottomWireframe);
                bottomWireframe.geometry.dispose();
                bottomWireframe = new THREE.LineSegments(
                    new THREE.EdgesGeometry(bottomGeo),
                    new THREE.LineBasicMaterial({ color: 0xaa8866, opacity: 0.2, transparent: true })
                );
                bottomMesh.add(bottomWireframe);
            }
 
            // --- Buttons ---
            document.getElementById('resetBtn').addEventListener('click', resetAll);
            document.getElementById('terrainBtn').addEventListener('click', generateRandomTerrain);
 
            // --- Animationsschleife ---
            function animate() {
                requestAnimationFrame(animate);
 
                // Drei Wellenschritte pro Frame (wie Original)
                waveStep();
                waveStep();
                waveStep();
 
                updateWaterGeometry();
                controls.update();
                renderer.render(scene, camera);
            }
 
            animate();
 
            window.addEventListener('resize', () => {
                camera.aspect = window.innerWidth / window.innerHeight;
                camera.updateProjectionMatrix();
                renderer.setSize(window.innerWidth, window.innerHeight);
            });
        })();
    </script>
</body>
</html>
